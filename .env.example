# ───────────────────────────────────────────────
# Studio Itai — Environment Variables
# העתק קובץ זה ל-.env.local ומלא את הערכים
# ───────────────────────────────────────────────

# Supabase
# Dashboard → Project Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=              # https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=  # sb_publishable_...  (browser-safe)
SUPABASE_SECRET_KEY=                   # sb_secret_...       (server-only, NEVER expose)

# Anthropic (Claude AI)
# https://console.anthropic.com/keys
ANTHROPIC_API_KEY=                     # sk-ant-...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
